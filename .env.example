# === Model Configuration ===
# Fill in one option. Priority: MODEL_NAME > API Key detection > Ollama local model

# Option A: Specify model directly
# MODEL_NAME=deepseek/deepseek-chat

# Option B: Set an API key (model auto-selected)
# DEEPSEEK_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# Option C: Leave everything empty — defaults to local Ollama (free)
# Install Ollama: https://ollama.com/download
# Pull a model: ollama pull qwen2.5:7b

# === Web Search (optional) ===
# Providers supported: duckduckgo (free, no key) / tavily / serpapi
# WEB_SEARCH_PROVIDER=tavily
# Provider API key. Can also be set in config.yaml under web.search_api_key.
# WEB_SEARCH_API_KEY=your_key_here
# Legacy env-var names still work as fallback:
# TAVILY_API_KEY=your_key_here
# SERPAPI_KEY=your_key_here
