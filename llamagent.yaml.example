# LlamAgent Configuration
# Copy this file to llamagent.yaml and modify as needed.
# Only include the fields you want to override; all others use defaults.
# Priority: Environment variables > This file > Code defaults

# ==================== Model ====================
model:
  name: ""                            # Model identifier (empty = auto-detect from API keys)
  # max_context_tokens: 0             # 0 = auto-detect via litellm
  # api_retry_count: 1

# ==================== Agent ====================
# agent:
#   system_prompt: "You are LlamAgent..."
#   context_window_size: 20
#   context_compress_threshold: 0.7
#   compress_keep_turns: 3
#   react:
#     max_steps: 10
#     max_duplicate_actions: 2
#     timeout: 210.0
#   max_observation_tokens: 2000

# ==================== Retrieval ====================
# retrieval:
#   persist_dir: "data/chroma"        # Where vector DB and FTS files are stored
#   embedding:
#     provider: "chromadb"            # "chromadb" (default) / future: "openai", "bge"
#     model: ""                       # Provider-specific model name (empty = default)

# ==================== Memory ====================
memory:
  write_mode: "off"                   # off / autonomous / hybrid
  recall_mode: "tool"                 # off / tool / auto
  # fact_fallback: "text"             # text (store as plain text on extraction failure) / drop
  # auto_recall:
  #   top_k: 5
  #   max_inject: 3
  #   threshold: 0.35

# ==================== RAG ====================
# rag:
#   top_k: 3
#   chunk_size: 500
#   retrieval_mode: "hybrid"          # vector / lexical / hybrid
#   rerank_enabled: true

# ==================== Planning ====================
# planning:
#   max_plan_adjustments: 7

# ==================== Reflection ====================
# reflection:
#   enabled: false
#   score_threshold: 7.0

# ==================== Safety ====================
# safety:
#   permission_level: 1

# ==================== Skill ====================
# skill:
#   dirs: []                          # Additional skill directory paths
#   max_active: 2
#   llm_fallback: false

# ==================== Job ====================
# job:
#   default_timeout: 300.0
#   max_active: 10
#   profiles: {}

# ==================== Web ====================
# web:
#   search_provider: ""              # "" = auto-detect from API keys, or: "duckduckgo" / "serpapi" / "tavily"
#   search_num_results: 5            # Default number of results per search

# ==================== Authorization ====================
# authorization:
#   mode: interactive          # interactive (default) | task | continuous
#   # Seed scopes for task/continuous mode (pre-authorized operations).
#   # Task mode: configured seed_scopes skip the prepare/contract flow (auto_execute).
#   # Continuous mode: defaults to project read/write when no seed_scopes configured.
#   # seed_scopes:
#   #   - scope: session
#   #     zone: project
#   #     actions: [write]
#   #     path_prefixes:
#   #       - "docs/"
#   #       - "src/"
#   #   - scope: session
#   #     zone: project
#   #     actions: [execute]
#   #     tool_names: [start_job]
#   #     path_prefixes:
#   #       - "scripts/"

# ==================== Output ====================
# output:
#   dir: "output/"

# ==================== Hooks ====================
# Event hooks for tool-level and lifecycle-level interception.
# Shell commands receive event data via environment variables ($HOOK_*).
# Exit code: 0 = allow, non-0 = block (only effective for pre_tool_use).
#
# hooks:
#   pre_tool_use:
#     - matcher:
#         tool_name: "start_job"
#       shell: "echo \"[PRE] $HOOK_TOOL_NAME\" >> /tmp/audit.log"
#     - matcher:
#         safety_level: 2
#       shell: "/usr/local/bin/policy-check"
#       # priority: 200                   # Lower = earlier (code hooks default 100, YAML default 200)
#
#   post_tool_use:
#     - shell: "echo \"[POST] $HOOK_TOOL_NAME ($HOOK_DURATION_MS ms)\" >> /tmp/audit.log"
#
#   tool_error:
#     - shell: "echo \"[ERROR] $HOOK_TOOL_NAME: $HOOK_ERROR\" >> /tmp/audit.log"
#
# Available environment variables:
#   $HOOK_EVENT          - Event type (pre_tool_use / post_tool_use / tool_error / ...)
#   $HOOK_TOOL_NAME      - Tool name
#   $HOOK_ARGS           - Tool arguments (JSON)
#   $HOOK_RESULT         - Tool result (post_tool_use only)
#   $HOOK_RESULT_PREVIEW - First 200 chars of result (post_tool_use only)
#   $HOOK_ERROR          - Error message (tool_error only)
#   $HOOK_DURATION_MS    - Execution time in ms (post_tool_use only)
